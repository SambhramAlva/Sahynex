# ── gitAgent Backend — Environment Variables ──────────────────────────
# Copy to .env and fill in values before running.

# ── AI Model (Ollama) ────────────────────────────────────────────────
# Ensure Ollama is running locally with the required model (qwen2.5-coder:7b)

# ── Security ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_32plus_char_string
JWT_EXPIRE_MINUTES=1440

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_generate_a_fernet_key

# ── Database ──────────────────────────────────────────────────────────
# SQLite (default for prototype). For Postgres: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=gitAgent.db

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── GitHub Webhook (optional) ─────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
